{
  "name": "Streamlit DevContainer",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "ms-python.mypy-type-checker",
        "ms-python.python",
        "ms-python.debugpy",
        "charliermarsh.ruff",
